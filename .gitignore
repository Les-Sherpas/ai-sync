# MCP servers manifest - customize locally; never commit
config/mcp-servers/servers.yaml

# MCP secrets: commit secret references only, ignore generated artifacts
config/mcp-servers/secrets/*

# Knowledge base
knowledge-base/*

# Sync backups
.sync_backups/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
scripts/.venv/
venv/
env/
*.egg-info/
.eggs/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Type checkers & linters
.ruff_cache/
.mypy_cache/

# Environment & secrets
.env
.env.*
!.env.example
!.env.tpl

# Client config (local overrides; example stays tracked)
config/client-settings/settings.yaml

# Logs & generated
*.log
knowledge-base/eval-logs.jsonl

# Node (for skills with .mjs scripts)
node_modules/

# IDE & OS
.idea/
.vscode/
.DS_Store
